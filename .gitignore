# Dependencies
node_modules/
.pnpm-store/
.yarn/

# Build output
dist/
build/
.out/
coverage/
.vite/

# Test output
vitest.config.*.timestamp-*
*.lcov

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment files
.env
.env.*
!.env.example

# Local editor and OS files
.DS_Store
Thumbs.db
Desktop.ini
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# TypeScript
*.tsbuildinfo

# Local caches
.cache/
.parcel-cache/
.eslintcache
.stylelintcache

# Temporary files
tmp/
temp/
*.tmp
*.swp
*.swo

# Package manager metadata that should not usually be committed across managers
.yarn/install-state.gz
.yarn/build-state.yml
.yarn/cache/

# Optional local browser/profiling captures
*.cpuprofile
*.heapsnapshot

# Local packaged archives
*.zip
*.tar
*.tar.gz
*.tgz
